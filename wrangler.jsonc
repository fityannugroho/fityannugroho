{
  "main": "@astrojs/cloudflare/entrypoints/server",
  "name": "fityannugroho",
  "compatibility_date": "2025-10-27",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  }
}
