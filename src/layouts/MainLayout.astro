---
import Footer from "@/components/Footer.astro";
import { Navbar } from "@/components/Navbar";
import type { Props as BaseLayoutProps } from "./BaseLayout.astro";
import BaseLayout from "./BaseLayout.astro";
import { isSupportedLocale, defaultLocale } from "@/lib/i18n";

export type Props = BaseLayoutProps & {
  /**
   * The class name for the main element.
   */
  className?: string;
  /**
   * Disables the default container wrapper.
   */
  disableWrapper?: boolean;
};

const { className, disableWrapper, ...props } = Astro.props;
const rawLocale = Astro.cookies.get("locale")?.value ?? null;
const locale = isSupportedLocale(rawLocale) ? rawLocale : defaultLocale;

const menus = [
  { title: "About", href: "/about" },
  { title: "Projects", href: "/projects" },
  { title: "Blog", href: "/blog" },
];
---

<BaseLayout {...props}>
  <Navbar client:only="react" items={menus} current={Astro.url.pathname} locale={locale} />
  <main
    class:list={[
      !disableWrapper && "container py-12",
      "min-h-[83vh]",
      className,
    ]}
  >
    <slot />
  </main>
  <Footer />
</BaseLayout>
